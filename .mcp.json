{
  "mcpServers": {
    "encore-mcp": {
        "args": [
            "mcp",
            "run",
            "--app=subs-check-uqti"
        ],
        "command": "encore"
    },
    "better-t-stack": {
      "command": "bunx",
      "args": ["create-better-t-stack@latest", "mcp"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    }
  }
}
